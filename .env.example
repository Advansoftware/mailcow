# Configuração Básica do Mailcow para Coolify
# Nome de domínio (FQDN) do seu servidor de e-mail
MAILCOW_HOSTNAME=mail.exemplo.com.br

# Timezone (ex: America/Sao_Paulo)
MAILCOW_TZ=America/Sao_Paulo

# Portas Internas (Deixe 8080/8443 para não conflitar com o Proxy do Coolify)
HTTP_PORT=8080
HTTPS_PORT=8443
HTTP_BIND=127.0.0.1
HTTPS_BIND=127.0.0.1

# Configurações de Banco de Dados (Serão geradas automaticamente se vazias)
DBNAME=mailcow
DBUSER=mailcow
DBPASS=
DBROOT=

# Senhas do Redis
REDISPASS=

# Outras configurações (Opcionais)
SKIP_LETS_ENCRYPT=n
SKIP_SOGO=n
SKIP_CLAMD=n
