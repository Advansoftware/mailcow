# --- Configuração Principal do Mailcow ---
# Este domínio será o host do painel (ex: mail.exemplo.com.br)
MAILCOW_HOSTNAME=mail.beeleads.com.br
MAILCOW_TZ=America/Sao_Paulo

# Portas para evitar conflito com o Coolify (Traefik)
HTTP_PORT=8080
HTTPS_PORT=8443

# --- Configuração de Automação ---
# Chave que será injetada no banco para permitir o provisionamento via API
# (Se mude esta chave, mude no script de injeção também)
INTERNAL_API_KEY=SUA_CHAVE_AQUI

# --- Domínios a serem criados (separados por vírgula) ---
COW_DOMAINS=dominio1.com,dominio2.net

# --- Contas de e-mail (Formato: dominio:usuario:senha:nome) ---
# O usuário é apenas a parte antes do @ (ex: 'admin' para 'admin@dominio1.com')
COW_MAILBOXES=dominio:usuario:senha:nome

# --- Apelidos/Aliases (Formato: dominio:alias:destino) ---
# Ex: webmaster@dominio1.com -> admin@dominio1.com
COW_ALIASES=dominio:alias:destino
