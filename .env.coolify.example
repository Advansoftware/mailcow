# Variáveis obrigatórias para o Coolify (Mailcow)
MAILCOW_HOSTNAME=mail.seudominio.com
TZ=America/Sao_Paulo

# Senhas (se não preencher, o init gerará aleatórias no primeiro boot)
# MAILCOW_DBPASS=
# MAILCOW_DBROOT=
# MAILCOW_REDISPASS=

# Configurações de Rede (Opcional, padrões recomendados abaixo)
HTTP_PORT=80
HTTPS_PORT=443
IPV4_NETWORK=172.22.1

# ACME / SSL
# MAILCOW_ACME_EMAIL=seu@email.com

# Se o servidor tiver pouca RAM (< 2.5GB), descomente abaixo:
# SKIP_CLAMD=y
